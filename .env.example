# ── Supabase (banco de dados) ──────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Gemini (LLM + embeddings) ──────────────────────────────────────────────────
# Obtenha em: aistudio.google.com/apikey
# GEMINI_API_KEY  → LLM principal (gemini-2.5-flash) — todos os agentes de extração e recomendação
# GEMINI_API_KEY2 → embeddings (gemini-embedding-001) + fallback automático quando a cota da chave principal é esgotada
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY2=your-gemini-api-key-fallback

# ── OpenRouter (geração de query semântica) ────────────────────────────────────
# Obtenha em: openrouter.ai/keys
# Modelo usado: openai/gpt-oss-120b:free
OPENROUTER_API_KEY=your-openrouter-api-key

# ── APIs de notícias ───────────────────────────────────────────────────────────
# NEWS_API_KEY  → fonte primária  (newsapi.org)
# NEWS_DATA_KEY → fallback 1     (newsdata.io)  — opcional
# GNNEWS_API_KEY → fallback 2    (gnews.io)     — opcional
# Os fallbacks são acionados automaticamente quando a fonte anterior retorna erro ou cota esgotada.
NEWS_API_KEY=your-newsapi-key
NEWS_DATA_KEY=your-newsdata-key
GNNEWS_API_KEY=your-gnews-key
